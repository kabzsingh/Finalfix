{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "auto",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/server.js",
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "NODE_ENV": "production"
  },
   "triggers": {
    "crons": ["0 * * * *"]
  }
}

